# =============================================================================
# .env.production.example — angelina-consultoria LiveKit production deployment
# =============================================================================
# DO NOT COMMIT .env.production — keep secrets out of git.
#
# Usage on the VPS:
#   cp .env.production.example .env.production
#   $EDITOR .env.production      # fill in real values
#   chmod 600 .env.production    # restrict permissions
#
# =============================================================================
# LiveKit API credentials
# =============================================================================
# Generate a real key + secret for prod. NEVER reuse devkey/secret.
#
# Generate a secret:
#   openssl rand -base64 32
#
# R13 footgun: the value of LIVEKIT_API_SECRET in this file MUST be the
# BASE64-ENCODED form of the raw secret (because docker/prod/livekit.yaml's
# `keys.<key>` field requires base64 once --dev is removed).
#
# Vercel side: Vercel's LIVEKIT_API_SECRET stores the RAW form (not base64)
# because the token signer sends it to LiveKit as the HMAC key — same
# algorithm, base64 on the file side, raw on the Vercel side.
#
# Workflow:
#   1. Generate raw secret:   openssl rand -base64 32  (copy output as RAW_SECRET)
#   2. Encode for VPS file:   echo -n "$RAW_SECRET" | base64
#   3. Put the base64 value in LIVEKIT_API_SECRET below (VPS side).
#   4. Put the RAW value in Vercel's LIVEKIT_API_SECRET (Vercel side).
LIVEKIT_API_KEY=replace-with-your-prod-api-key
LIVEKIT_API_SECRET=replace-with-base64-of-your-prod-secret

# =============================================================================
# Vercel-side env var (also referenced on VPS — same URL, different scopes)
# =============================================================================
# R7: NEXT_PUBLIC_* is inlined at BUILD TIME on Vercel. Setting it as a
# runtime-only env var will NOT work — the build step inlines the Vercel
# default (ws://localhost:7880) into the client bundle instead.
#
# Vercel scope: in the project env vars page, set scope = "Build Command"
# or "Both" for this var. Lambda-only is the wrong scope.
#
# The same value (https URL) is referenced from the VPS perspective — it's
# the URL the browser dials when joining a call.
NEXT_PUBLIC_LIVEKIT_URL=https://livekit.angelina-consultoria.com

# =============================================================================
# Webhook URL (LiveKit → Vercel, server-to-server)
# =============================================================================
# MUST be the PUBLIC Vercel URL — not host.docker.internal (the VPS has no
# Next.js dev server in prod; host.docker.internal resolves to the VPS
# loopback). The webhook is server-to-server: LiveKit makes an outbound
# HTTPS call from the VPS to this URL.
LIVEKIT_WEBHOOK_URL=https://angelina-consultoria.com/api/livekit/webhook

# =============================================================================
# Caddy (TLS terminator)
# =============================================================================
# CADDY_DOMAIN: subdomain the cert is issued for. The A record for this
# hostname MUST point at the VPS public IP BEFORE Caddy's first ACME run.
# CADDY_EMAIL: email Let's Encrypt uses to notify about cert issues. Required
# by Let's Encrypt's ToS.
CADDY_DOMAIN=livekit.angelina-consultoria.com
CADDY_EMAIL=ops@angelina-consultoria.com

# =============================================================================
# Node IP (WebRTC SDP candidates)
# =============================================================================
# R12: the public IP or DDNS hostname that the LiveKit server advertises in
# SDP candidates. MUST be reachable from the browser; a private IP (e.g.
# the docker bridge 172.17.0.x) breaks WebRTC negotiation.
#
# Static public IP: set to the VPS public IP, e.g. LIVEKIT_NODE_IP=203.0.113.42
# DDNS (dynamic IP): set to the DDNS hostname, e.g. LIVEKIT_NODE_IP=myhost.duckdns.org
# Caddy ACME works with DDNS as long as the A record is propagated before issuance.
LIVEKIT_NODE_IP=