# =============================================================================
# .env.example — angelina-consultoria (commit-safe placeholder values)
# =============================================================================
# Copy to .env.local for dev. Real values for production live in Vercel's
# project Environment Variables page (see docs/deployment.md).
#
# ADR-0001 (Vercel-Only): MinIO, MeiliSearch, and self-hosted LiveKit are
# retired. The remaining infrastructure is Vercel + Upstash REST + LiveKit
# Cloud + (forward-looking) Vercel Blob.

# ─── Database ──────────────────────────────────────────────────────────────
# Local dev (Docker Postgres): postgres://angelina:angelina_pass@localhost:5432/angelina_consultoria
# Production (Vercel Postgres): the auto-injected POSTGRES_URL with
#   `?pgbouncer=true&connection_limit=1` appended. See src/infrastructure/db/index.ts.
DATABASE_URL=postgres://angelina:angelina_pass@localhost:5432/angelina_consultoria

# ─── Auth.js v5 ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
# Required on Vercel — the edge terminates TLS and proxies internally,
# so NextAuth cannot auto-detect the canonical host without this.
AUTH_TRUST_HOST=true
# Vercel injects VERCEL_URL automatically; setting AUTH_URL explicitly is
# recommended but optional (NextAuth falls back to request URL).
# AUTH_URL=https://$VERCEL_URL

# ─── LiveKit Cloud (https://livekit.cloud) ─────────────────────────────────
# Free dev project, no credit card. Copy values from the Cloud dashboard.
# `NEXT_PUBLIC_LIVEKIT_URL` is build-time inlined — see docs/deployment.md.
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=replace-with-base64-from-dashboard
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Webhook URL configured in the LiveKit Cloud dashboard, not here.
# Local dev: http://host.docker.internal:3000/api/livekit/webhook
# Production: https://<your-vercel-domain>/api/livekit/webhook
LIVEKIT_WEBHOOK_URL=http://host.docker.internal:3000/api/livekit/webhook

# ─── Upstash REST (https://upstash.com) ────────────────────────────────────
# Free dev DB, no credit card. Copy URL + token from the Upstash console.
# Used by cache.ts, rate-limiter.ts, and webhookDedupe. When unset, all
# three degrade to no-op gracefully.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# ─── Object storage (Vercel Blob, forward-looking) ─────────────────────────
# No current source uses storage. Set when @vercel/blob is wired in.
# Default for next/image remotePatterns is *.public.blob.vercel-storage.com.
MINIO_PUBLIC_HOSTNAME=your-blob.public.blob.vercel-storage.com

# ─── App ───────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
