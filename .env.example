# PostgreSQL (required for the app to boot)
DATABASE_URL=postgres://user:password@localhost:5432/angelina-consultoria

# Test database (optional — if unset, integration tests are skipped)
# Use a separate database so tests can freely truncate tables:
# TEST_DATABASE_URL=postgres://user:password@localhost:5432/angelina-consultoria-test

# Redis (optional — enables caching + rate limiting)
# REDIS_URL=redis://localhost:6379

# PostHog (optional — if unset, analytics are silently skipped)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com

# LiveKit (video calls — self-hosted SFU)
# Get these from your LiveKit deployment. For local dev, use devkey/secret (the defaults of livekit-server --dev).
LIVEKIT_API_KEY=changeme
LIVEKIT_API_SECRET=changeme-in-prod
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit webhook delivery URL (self-hosted SFU).
# Used by docker/dev/livekit.yaml via ${LIVEKIT_WEBHOOK_URL:-<default>} to
# configure where the container POSTs room_finished events.
# Default points to the Next.js dev server's /api/livekit/webhook handler.
# `host.docker.internal` works out of the box on Mac/Windows Docker Desktop;
# on Linux, docker-compose.yml's extra_hosts maps it to host-gateway so the
# LiveKit container can reach the Next.js dev server on the host.
# Override here if you run `next dev --port <other>` (and restart
# `docker compose up -d livekit` so the container picks up the new env var).
LIVEKIT_WEBHOOK_URL=http://host.docker.internal:3000/api/livekit/webhook
