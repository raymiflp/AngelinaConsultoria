# =============================================================================
# Caddyfile for LiveKit prod HTTPS termination
# =============================================================================
# Why Caddy: built-in ACME, auto-renewal at 30 days before expiry, single
# binary, no certbot cron. The whole TLS story is this file + the cert+data
# volumes.
#
# Mounted at /etc/caddy/Caddyfile in the caddy container (see
# docker/prod/docker-compose.override.yml). The {$CADDY_DOMAIN} placeholder
# is substituted by Caddy at startup from the environment.

{$CADDY_DOMAIN:livekit.angelina-consultoria.com} {
    # ACME email for Let's Encrypt registration
    email {$CADDY_EMAIL:ops@angelina-consultoria.com}

    # HSTS preload
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Reverse-proxy to LiveKit container on the docker network
    reverse_proxy angelina-livekit:7880 {
        # Pass-through WebSocket upgrade headers for LiveKit SDK
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Logging
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }

    encode zstd gzip
}

# :80 — ACME challenge only, redirect everything else to HTTPS
:80 {
    redir https://{host}{uri} permanent
}